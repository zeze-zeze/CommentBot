{
  "manifest_version": 3,
  "name": "CommentBot",
  "version": "1.2.0",
  "description": "在 YouTube 或 Facebook 的留言回覆框聚焦時，用你選擇的 AI（Claude / DeepSeek / ChatGPT）針對當下那一則留言產生回覆草稿，由你確認後手動送出",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": ["providers.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CommentBot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
